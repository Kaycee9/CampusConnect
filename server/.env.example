NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/campusconnect
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CLIENT_URL=http://localhost:5173

# Ledger / settlement
LEDGER_CURRENCY=NGN
LEDGER_SETTLEMENT_DELAY_HOURS=24

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Paystack
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_PUBLIC_KEY=pk_test_
PLATFORM_FEE_PERCENT=10

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="CampusConnect <noreply@campusconnect.app>"
